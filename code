#include <ESP8266WiFi.h>
#include <WiFiUdp.h>

const char* ssid     = "2586LabsGuest";
const char* password = "hackinout";
const char* pcIP     = "192.168.0.71"; // Your PC's IP
const int port       = 5005;

// Pin Definitions
#define UP_PIN    D1
#define DOWN_PIN  D2
#define LEFT_PIN  D3
#define RIGHT_PIN D4
#define L_CLICK   D5
#define R_CLICK   D6
#define M_CLICK   D7

WiFiUDP udp;

void setup() {
  Serial.begin(115200);
  
  // Initialize all 7 pins as input with internal pullup resistors
  int pins[] = {UP_PIN, DOWN_PIN, LEFT_PIN, RIGHT_PIN, L_CLICK, R_CLICK, M_CLICK};
  for(int i=0; i<7; i++) {
    pinMode(pins[i], INPUT_PULLUP);
  }

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nReady!");
}

void loop() {
  int xMove = 0;
  int yMove = 0;
  int speed = 12; // Change this to make mouse move faster/slower

  // Movement Logic
  if (digitalRead(UP_PIN) == LOW)    yMove = -speed;
  if (digitalRead(DOWN_PIN) == LOW)  yMove = speed;
  if (digitalRead(LEFT_PIN) == LOW)   xMove = -speed;
  if (digitalRead(RIGHT_PIN) == LOW)  xMove = speed;

  // Click Logic (1 if pressed, 0 if not)
  int lClick = (digitalRead(L_CLICK) == LOW);
  int rClick = (digitalRead(R_CLICK) == LOW);
  int mClick = (digitalRead(M_CLICK) == LOW);

  // Send packet only if something is happening
  if (xMove != 0 || yMove != 0 || lClick || rClick || mClick) {
    String msg = String(xMove) + "," + String(yMove) + "," + String(lClick) + "," + String(rClick) + "," + String(mClick);
    udp.beginPacket(pcIP, port);
    udp.print(msg);
    udp.endPacket();
  }

  delay(10); // Smoothness control
}
