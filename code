// ============================================================
//  WiFi Mouse Transmitter — ESP8266
//  Fixes: click debounce, diagonal normalization, faster string building
// ============================================================

#include <ESP8266WiFi.h>
#include <WiFiUdp.h>

// --- Configuration ---
const char* ssid     = "2586Labs Guest";
const char* password = "hackinout";
const char* pcIP     = "192.168.0.71";
const int   port     = 5005;

// --- Pin Definitions ---
#define UP_PIN    D1   // GPIO5
#define DOWN_PIN  D2   // GPIO4
#define LEFT_PIN  D6   // GPIO0  <-- unplug before upload!
#define RIGHT_PIN D7   // GPIO2  <-- unplug before upload!
#define L_CLICK   D8   // GPIO14
#define R_CLICK   D0   // GPIO12
#define M_CLICK   D7   // GPIO13

WiFiUDP udp;

// --- Click state tracking (to send press/release, not spam) ---
bool prevL = false, prevR = false, prevM = false;

// Diagonal speed multiplier  (1/√2 ≈ 0.707)
const float DIAG = 0.707f;
const int   SPEED = 15;

void setup() {
  Serial.begin(115200);
  delay(500);

  int pins[] = {UP_PIN, DOWN_PIN, LEFT_PIN, RIGHT_PIN, L_CLICK, R_CLICK, M_CLICK};
  for (int i = 0; i < 7; i++) {
    pinMode(pins[i], INPUT_PULLUP);
  }

  Serial.print("Connecting to WiFi");
  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  Serial.println("\nConnected! IP: " + WiFi.localIP().toString());
}

void loop() {
  // --- Read direction buttons ---
  bool goUp    = (digitalRead(UP_PIN)    == LOW);
  bool goDown  = (digitalRead(DOWN_PIN)  == LOW);
  bool goLeft  = (digitalRead(LEFT_PIN)  == LOW);
  bool goRight = (digitalRead(RIGHT_PIN) == LOW);

  // --- Read click buttons ---
  bool curL = (digitalRead(L_CLICK) == LOW);
  bool curR = (digitalRead(R_CLICK) == LOW);
  bool curM = (digitalRead(M_CLICK) == LOW);

  // --- Compute movement with diagonal normalization ---
  float xMove = 0, yMove = 0;
  bool moving = (goUp || goDown || goLeft || goRight);

  if (goUp)    yMove -= SPEED;
  if (goDown)  yMove += SPEED;
  if (goLeft)  xMove -= SPEED;
  if (goRight) xMove += SPEED;

  // If moving diagonally, scale down so speed stays consistent
  bool diagonal = (goUp || goDown) && (goLeft || goRight);
  if (diagonal) {
    xMove *= DIAG;
    yMove *= DIAG;
  }

  // --- Click encoding ---
  // Bits: bit0=leftDown, bit1=leftUp, bit2=rightDown, bit3=rightUp,
  //       bit4=middleDown, bit5=middleUp
  // This lets the receiver know exactly what changed each packet.
  int clickBits = 0;
  if (curL && !prevL)  clickBits |= (1 << 0);  // left press
  if (!curL && prevL)  clickBits |= (1 << 1);  // left release
  if (curR && !prevR)  clickBits |= (1 << 2);  // right press
  if (!curR && prevR)  clickBits |= (1 << 3);  // right release
  if (curM && !prevM)  clickBits |= (1 << 4);  // middle press
  if (!curM && prevM)  clickBits |= (1 << 5);  // middle release

  prevL = curL;
  prevR = curR;
  prevM = curM;

  // --- Only transmit when there is something to report ---
  if (moving || clickBits != 0) {
    char buf[32];
    // Format: "xi,yi,clickBits"  (integers to keep packet tiny)
    snprintf(buf, sizeof(buf), "%d,%d,%d",
             (int)xMove, (int)yMove, clickBits);

    udp.beginPacket(pcIP, port);
    udp.print(buf);
    udp.endPacket();
  }

  delay(15);  // ~66 Hz update rate
}
